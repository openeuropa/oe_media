{
    "name": "openeuropa/oe_media",
    "description": "Media features for the OpenEuropa project.",
    "type": "drupal-module",
    "license": "EUPL-1.2",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.1",
        "drupal/core": "^10.3 || ^11",
        "drupal/embed": "^1.10",
        "drupal/entity_browser": "^2.12",
        "drupal/file_link": "dev-3430560-automated-drupal-11",
        "drupal/inline_entity_form": "^3.0@RC",
        "drupal/media_avportal": "dev-3431855-automated-drupal-11",
        "drupal/remote_stream_wrapper": "dev-d11-compatibility#5e9eb8d290f78f69464ab01ed374439992985811"
    },
    "require-dev": {
        "cweagans/composer-patches": "^1.7 | ^2.0",
        "composer/installers": "~1.5",
        "drupal/composite_reference": "^2.2",
        "drupal/config_devel": "^1.9",
        "drupal/core-composer-scaffold": "^10.3 || ^11",
        "drupal/core-dev": "^10.3 || ^11",
        "drupal/drupal-extension": "^5.0",
        "drupal/entity_reference_revisions": "^1.7",
        "drupal/json_field": "^1.1",
        "drush/drush": "^12.4 || ^13",
        "mikey179/vfsstream": "^1.6",
        "nikic/php-parser": "^4.18",
        "openeuropa/behat-transformation-context": "^0.2",
        "openeuropa/code-review-drupal": "^1.0.0-alpha",
        "openeuropa/oe_link_lists": "dev-EWPP-4628",
        "openeuropa/oe_oembed": "dev-EWPP-4603",
        "openeuropa/oe_webtools": "dev-EWPP-4629",
        "openeuropa/task-runner-drupal-project-symlink": "^1.0"
    },
    "scripts": {
        "post-install-cmd": "./vendor/bin/run drupal:site-setup",
        "post-update-cmd": "./vendor/bin/run drupal:site-setup"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8",
            "exclude": [
                "drupal/file_link",
                "drupal/media_avportal",
                "drupal/remote_stream_wrapper"
            ]
        },
        {
            "type": "git",
            "url": "https://git.drupalcode.org/issue/file_link-3430560.git",
            "reference": "e919bf13b4a14ac0bb1504bcbd04a80504466bb4"
        },
        {
            "type": "git",
            "url": "https://git.drupalcode.org/issue/media_avportal-3431855.git",
            "reference": "1475bf7a0795f337cd007bc94780dc6041787cf3"
        },
        {
            "type": "git",
            "url": "https://github.com/openeuropa/oe_link_lists.git"
        },
        {
            "type": "git",
            "url": "https://github.com/openeuropa/oe_oembed.git"
        },
        {
            "type": "git",
            "url": "https://github.com/openeuropa/oe_webtools.git"
        },
        {
            "type": "git",
            "url": "https://github.com/openeuropa/DrupalDriver.git"
        },
        {
            "type": "git",
            "url": "https://github.com/openeuropa/code-review-drupal.git"
        },
        {
            "type": "package",
            "package": {
                "name": "drupal/remote_stream_wrapper",
                "version": "dev-d11-compatibility",
                "type": "drupal-module",
                "source": {
                    "type": "git",
                    "url": "https://git.drupalcode.org/issue/remote_stream_wrapper-3434168.git",
                    "reference": "5e9eb8d290f78f69464ab01ed374439992985811"
                }
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "Drupal\\oe_media\\": "./src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Drupal\\Tests\\oe_media\\": "./tests/src",
            "Drupal\\Tests\\oe_media_embed\\": "./modules/oe_media_embed/tests/src",
            "Drupal\\Tests\\oe_media_circabc\\": "./modules/oe_media_circabc/tests/src",
            "Drupal\\Tests\\oe_link_lists\\": "./build/modules/contrib/oe_link_lists/tests/src",
            "Drupal\\Tests\\oe_link_lists_manual_source\\": "./build/modules/contrib/oe_link_lists/modules/oe_link_lists_manual_source/tests/src",
            "Drupal\\FunctionalJavascriptTests\\": "./build/core/tests/Drupal/FunctionalJavascriptTests"
        }
    },
    "extra": {
        "composer-exit-on-patch-failure": true,
        "enable-patching": true,
        "installer-paths": {
            "build/core": [
                "type:drupal-core"
            ],
            "build/profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "build/modules/contrib/{$name}": [
                "type:drupal-module"
            ]
        },
        "drupal-scaffold": {
            "locations": {
                "web-root": "./build"
            }
        },
        "_readme": [
            "Explicit requirement of nikic/php-parser as ^5.0 generates GrumPHP Parser issues."
        ]
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "cweagans/composer-patches": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "drupal/core-composer-scaffold": true,
            "php-http/discovery": false,
            "phpro/grumphp": true,
            "phpro/grumphp-shim": true,
            "phpstan/extension-installer": true,
            "tbachert/spi": false
        },
        "sort-packages": true
    }
}
